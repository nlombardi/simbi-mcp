model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

	table sales_small
		lineageTag: 3501b34b-dd04-4c2e-bec1-6a3c70624154

		/// Sum of all revenue across transactions
		measure 'Total Revenue' = SUM(sales_small[Revenue])
			formatString: $#,0.00
			displayFolder: Key Metrics
			lineageTag: ae5c6441-8fad-4934-a1e8-98741e095efc

		/// Estimated total cost (65% of revenue). Replace with SUM(sales_small[Cost]) when a cost column is available.
		measure 'Total Cost' = SUMX(sales_small, sales_small[UnitsSold] * sales_small[UnitPrice] * 0.65)
			formatString: $#,0.00
			isHidden
			displayFolder: Key Metrics
			lineageTag: 67f837d0-3951-4036-b661-d1c811970a29

		/// Gross profit margin as a percentage of revenue. Uses estimated cost (65% of revenue) until a real cost column is added.
		measure 'Profit Margin %' = DIVIDE([Total Revenue] - [Total Cost], [Total Revenue], BLANK())
			formatString: 0.0%
			displayFolder: Key Metrics
			lineageTag: 8f90bc7a-cb45-4128-a7a2-9364e8347ce8

		column OrderID
			dataType: int64
			formatString: 0
			lineageTag: 477e7f02-58dc-4404-abb8-af1c3457fe6c
			summarizeBy: count
			sourceColumn: OrderID

			annotation SummarizationSetBy = Automatic

		column OrderDate
			dataType: dateTime
			formatString: Long Date
			lineageTag: ad1d6d78-ef2d-47d1-82d0-135840307ac8
			summarizeBy: none
			sourceColumn: OrderDate

			variation Variation
				isDefault
				relationship: 0a5924e8-ec8c-4266-ade7-29a18103e2e5
				defaultHierarchy: LocalDateTable_9d3e2dd8-c305-4b1c-8835-86dc75a30ce1.'Date Hierarchy'

			annotation SummarizationSetBy = Automatic

			annotation UnderlyingDateTimeDataType = Date

		column Region
			dataType: string
			lineageTag: 6a687f6a-e297-4c6c-972f-52fdad1a526a
			summarizeBy: none
			sourceColumn: Region

			annotation SummarizationSetBy = Automatic

		column Product
			dataType: string
			lineageTag: 4ebe9c7f-70d7-4d68-b81b-f26821d78b7a
			summarizeBy: none
			sourceColumn: Product

			annotation SummarizationSetBy = Automatic

		column Category
			dataType: string
			lineageTag: d23d2e7a-a7dd-4962-90c8-6b6390a626eb
			summarizeBy: none
			sourceColumn: Category

			annotation SummarizationSetBy = Automatic

		column UnitsSold
			dataType: int64
			formatString: 0
			lineageTag: f47418dd-4270-4a4d-a97f-805de2ee90b1
			summarizeBy: sum
			sourceColumn: UnitsSold

			annotation SummarizationSetBy = Automatic

		column UnitPrice
			dataType: double
			lineageTag: 9222ca40-6873-4538-a72a-576b5c008ab8
			summarizeBy: sum
			sourceColumn: UnitPrice

			annotation SummarizationSetBy = Automatic

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		column Revenue
			dataType: double
			lineageTag: e1405904-abcc-4972-961b-eb1350894dd3
			summarizeBy: sum
			sourceColumn: Revenue

			annotation SummarizationSetBy = Automatic

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		partition sales_small = m
			mode: import
			source =
					let
					    Source = Csv.Document(File.Contents("Q:\Development\DataSense\Tutorials\PowerBI\test\Data\sales_small.csv"),[Delimiter=",", Columns=8, Encoding=1252, QuoteStyle=QuoteStyle.None]),
					    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"OrderID", Int64.Type}, {"OrderDate", type date}, {"Region", type text}, {"Product", type text}, {"Category", type text}, {"UnitsSold", Int64.Type}, {"UnitPrice", type number}, {"Revenue", type number}})
					in
					    #"Changed Type"

		annotation PBI_ResultType = Table

