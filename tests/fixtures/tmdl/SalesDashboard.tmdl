	/// Date dimension for time intelligence
	table Date
		lineageTag: f138fff5-6c1c-452c-bf40-0c99be45654c
		dataCategory: Time

		column Date
			isUnique
			isNameInferred
			sourceColumn: [Date]

		column Year
			isNameInferred
			sourceColumn: [Year]

		column QuarterNumber
			isNameInferred
			sourceColumn: [QuarterNumber]

		column Quarter
			isNameInferred
			sourceColumn: [Quarter]

		column MonthNumber
			isNameInferred
			sourceColumn: [MonthNumber]

		column MonthName
			isNameInferred
			sourceColumn: [MonthName]

		column DayOfWeek
			isNameInferred
			sourceColumn: [DayOfWeek]

		column WeekdayName
			isNameInferred
			sourceColumn: [WeekdayName]

		partition Date = calculated
			mode: import
			source =
					ADDCOLUMNS(
					    CALENDARAUTO(),
					    "Year", YEAR([Date]),
					    "QuarterNumber", QUARTER([Date]),
					    "Quarter", "Q" & QUARTER([Date]),
					    "MonthNumber", MONTH([Date]),
					    "MonthName", FORMAT([Date], "MMMM"),
					    "DayOfWeek", WEEKDAY([Date], 2),
					    "WeekdayName", FORMAT([Date], "DDDD")
					)

	relationship 0a5924e8-ec8c-4266-ade7-29a18103e2e5
		joinOnDateBehavior: datePartOnly
		fromColumn: sales_small.OrderDate
		toColumn: LocalDateTable_9d3e2dd8-c305-4b1c-8835-86dc75a30ce1.Date

	relationship sales_small_OrderDate_Date_Date
		fromColumn: sales_small.OrderDate
		toColumn: Date.Date

